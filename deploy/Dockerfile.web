# web (TanStack Start). Build with Bun (repo policy: Bun-only for JS/TS), run the
# TanStack Start server output. The same-origin /v1/traces proxy forwards browser
# OTLP to Rotel server-side (ROTEL_OTLP_HTTP_ENDPOINT).
FROM oven/bun:1 AS build
WORKDIR /app
COPY web/package.json web/bun.lock ./
RUN bun install --frozen-lockfile
COPY web/ ./
RUN bun run build

FROM oven/bun:1 AS run
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY web/server.mjs ./server.mjs
EXPOSE 3000
CMD ["bun", "server.mjs"]
