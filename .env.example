# Copy to .env and uncomment only what you need.
#
# OTLP / Parallax
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
# PARALLAX_ENV=playground
#
# Sentry placeholders, not real DSNs.
# SENTRY_DSN=__set_me__
# VITE_SENTRY_DSN=__set_me__
#
# Scenario/resource knobs
# RELEASE=dev
# POSTGRES_PASSWORD=playground
# CHECKOUT_URL=http://localhost:8088
# ORDERS_URL=http://localhost:8092
# FULFILLMENT_URL=http://localhost:8093
# FLAGD_HOST=flagd
